# ── ElevenLabs ────────────────────────────────────────────────────────────────
# Get your key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Voice ID for the receptionist persona.
# Default: "Rachel" (21m00Tcm4TlvDq8ikWAM) — warm, professional female voice.
# Browse voices at https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Chat model for the receptionist. Optional — defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini

# ── Google Calendar ───────────────────────────────────────────────────────────
# Calendar ID to use for bookings. Use "primary" for the service account's
# own calendar, or a specific calendar ID (e.g. abc123@group.calendar.google.com).
# IMPORTANT: Share this calendar with the service account's client_email and
# grant "Make changes to events" permission.
GOOGLE_CALENDAR_ID=primary
# Path to the service account JSON key file (relative to project root)
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service_account.json

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=7860
# Log verbosity. Set to DEBUG to enable per-frame audio-level and VAD/transcription
# diagnostics (noisy — leave at INFO for demos).
LOG_LEVEL=INFO
